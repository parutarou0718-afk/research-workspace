{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-workspace.local/schemas/domain-event-read-1.0-2.0.json",
  "title": "DomainEvent readable versions",
  "oneOf": [
    {"$ref": "#/$defs/domainEventV1"},
    {"$ref": "#/$defs/domainEventV2"}
  ],
  "$defs": {
    "uuid": {"type": "string", "format": "uuid", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
    "nullableUuid": {"anyOf": [{"$ref": "#/$defs/uuid"}, {"type": "null"}]},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utcDateTime": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "domainEventV1": {
      "type": "object",
      "required": ["schema_version", "event_id", "event_type", "occurred_at", "actor", "aggregate", "payload", "deduplication_key"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "event_id": {"$ref": "#/$defs/uuid"},
        "event_type": {"enum": ["document.imported", "paper.created", "paper.version_added", "paper.version_relation_corrected", "idea.created", "idea.candidate_extracted", "idea.linked", "submission.created", "submission.status_changed", "context.recovered", "task.failed", "audit.undo_applied"]},
        "occurred_at": {"$ref": "#/$defs/utcDateTime"},
        "actor": {
          "type": "object",
          "required": ["actor_type", "actor_id"],
          "properties": {
            "actor_type": {"enum": ["user", "system", "task_executor", "agent"]},
            "actor_id": {"type": ["string", "null"], "maxLength": 255}
          },
          "additionalProperties": false
        },
        "aggregate": {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "type": {"enum": ["Paper", "PaperVersion", "Idea", "SourceDocument", "Submission", "Conference", "Grant", "Task", "AuditLog"]},
            "id": {"$ref": "#/$defs/uuid"}
          },
          "additionalProperties": false
        },
        "payload": {"type": "object"},
        "deduplication_key": {"type": "string", "minLength": 1, "maxLength": 255},
        "causation_id": {"$ref": "#/$defs/nullableUuid"},
        "correlation_id": {"$ref": "#/$defs/nullableUuid"}
      },
      "additionalProperties": false
    },
    "domainEventV2": {
      "allOf": [
        {"$ref": "#/$defs/domainEventV2Envelope"},
        {"$ref": "#/$defs/domainEventV2PayloadRegistry"},
        {
          "if": {"properties": {"actor_type": {"const": "user"}}, "required": ["actor_type"]},
          "then": {"properties": {"command_id": {"$ref": "#/$defs/uuid"}}}
        },
        {
          "if": {"properties": {"actor_type": {"const": "system"}}, "required": ["actor_type"]},
          "then": {
            "properties": {
              "operation_id": {"$ref": "#/$defs/uuid"},
              "correlation_id": {"$ref": "#/$defs/uuid"}
            }
          }
        }
      ]
    },
    "domainEventV2Envelope": {
      "type": "object",
      "required": ["schema_version", "event_id", "event_type", "occurred_at", "workspace_id", "command_id", "operation_id", "aggregate_type", "aggregate_id", "aggregate_version", "actor_type", "correlation_id", "causation_id", "payload"],
      "properties": {
        "schema_version": {"const": "2.0"},
        "event_id": {"$ref": "#/$defs/uuid"},
        "event_type": {"type": "string", "minLength": 1, "maxLength": 128},
        "occurred_at": {"$ref": "#/$defs/utcDateTime"},
        "workspace_id": {"$ref": "#/$defs/uuid"},
        "command_id": {"$ref": "#/$defs/nullableUuid"},
        "operation_id": {"$ref": "#/$defs/nullableUuid"},
        "aggregate_type": {"type": "string", "minLength": 1, "maxLength": 128},
        "aggregate_id": {"$ref": "#/$defs/uuid"},
        "aggregate_version": {"type": ["integer", "null"], "minimum": 1},
        "actor_type": {"enum": ["user", "system"]},
        "correlation_id": {"$ref": "#/$defs/nullableUuid"},
        "causation_id": {"$ref": "#/$defs/nullableUuid"},
        "payload": {"type": "object"}
      },
      "additionalProperties": false
    },
    "domainEventV2PayloadRegistry": {
      "oneOf": [
        {"$ref": "#/$defs/sourceSnapshotEvent"},
        {"$ref": "#/$defs/parseSucceededEvent"},
        {"$ref": "#/$defs/parseFailedEvent"},
        {"$ref": "#/$defs/monitoringRootEvent"},
        {"$ref": "#/$defs/reconciliationEvent"},
        {"$ref": "#/$defs/candidateDetectedEvent"},
        {"$ref": "#/$defs/candidateStateEvent"},
        {"$ref": "#/$defs/entityMutationEvent"},
        {"$ref": "#/$defs/submissionStatusEvent"},
        {"$ref": "#/$defs/paperVersionEvent"},
        {"$ref": "#/$defs/currentVersionEvent"},
        {"$ref": "#/$defs/versionRelationEvent"},
        {"$ref": "#/$defs/relationStateEvent"},
        {"$ref": "#/$defs/undoEvent"},
        {"$ref": "#/$defs/backupEvent"},
        {"$ref": "#/$defs/exportEvent"},
        {"$ref": "#/$defs/restorePreparedEvent"},
        {"$ref": "#/$defs/restoreActivatedEvent"},
        {"$ref": "#/$defs/migrationEvent"}
      ]
    },
    "sourceSnapshotEvent": {
      "properties": {
        "event_type": {"enum": ["source.snapshot_imported", "source.snapshot_reused"]},
        "payload": {"$ref": "#/$defs/sourceSnapshotPayload"}
      },
      "required": ["event_type", "payload"]
    },
    "sourceSnapshotPayload": {
      "type": "object",
      "required": ["snapshot_id", "source_observation_id", "import_item_id", "sha256", "size_bytes"],
      "properties": {
        "snapshot_id": {"$ref": "#/$defs/uuid"},
        "source_observation_id": {"$ref": "#/$defs/uuid"},
        "import_item_id": {"$ref": "#/$defs/uuid"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "parseSucceededEvent": {"properties": {"event_type": {"const": "document.parse_succeeded"}, "payload": {"$ref": "#/$defs/parseSucceededPayload"}}, "required": ["event_type", "payload"]},
    "parseSucceededPayload": {
      "type": "object",
      "required": ["parse_artifact_id", "source_snapshot_id", "parse_attempt_id", "block_count", "warning_codes"],
      "properties": {
        "parse_artifact_id": {"$ref": "#/$defs/uuid"}, "source_snapshot_id": {"$ref": "#/$defs/uuid"},
        "parse_attempt_id": {"$ref": "#/$defs/uuid"}, "block_count": {"type": "integer", "minimum": 0},
        "warning_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}}
      },
      "additionalProperties": false
    },
    "parseFailedEvent": {"properties": {"event_type": {"const": "document.parse_failed"}, "payload": {"$ref": "#/$defs/parseFailedPayload"}}, "required": ["event_type", "payload"]},
    "parseFailedPayload": {
      "type": "object",
      "required": ["parse_artifact_id", "source_snapshot_id", "parse_attempt_id", "error_code"],
      "properties": {"parse_artifact_id": {"$ref": "#/$defs/uuid"}, "source_snapshot_id": {"$ref": "#/$defs/uuid"}, "parse_attempt_id": {"$ref": "#/$defs/uuid"}, "error_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}},
      "additionalProperties": false
    },
    "monitoringRootEvent": {"properties": {"event_type": {"enum": ["monitoring.root_added", "monitoring.root_paused", "monitoring.root_resumed", "monitoring.root_removed", "monitoring.root_status_changed"]}, "payload": {"$ref": "#/$defs/monitoringRootPayload"}}, "required": ["event_type", "payload"]},
    "monitoringRootPayload": {"type": "object", "required": ["monitoring_root_id", "old_status", "new_status"], "properties": {"monitoring_root_id": {"$ref": "#/$defs/uuid"}, "old_status": {"oneOf": [{"enum": ["active", "paused", "disconnected", "degraded", "overflow_reconciling", "error"]}, {"type": "null"}]}, "new_status": {"oneOf": [{"enum": ["active", "paused", "disconnected", "degraded", "overflow_reconciling", "error"]}, {"type": "null"}]}}, "additionalProperties": false},
    "reconciliationEvent": {"properties": {"event_type": {"const": "monitoring.reconciliation_completed"}, "payload": {"$ref": "#/$defs/reconciliationPayload"}}, "required": ["event_type", "payload"]},
    "reconciliationPayload": {"type": "object", "required": ["reconciliation_run_id", "monitoring_root_id", "reason", "items_seen", "items_suspected_changed"], "properties": {"reconciliation_run_id": {"$ref": "#/$defs/uuid"}, "monitoring_root_id": {"$ref": "#/$defs/uuid"}, "reason": {"enum": ["baseline", "disconnect", "overflow", "unclean_shutdown", "user_verify"]}, "items_seen": {"type": "integer", "minimum": 0}, "items_suspected_changed": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "candidateDetectedEvent": {"properties": {"event_type": {"const": "paper_version_candidate.detected"}, "payload": {"$ref": "#/$defs/candidateDetectedPayload"}}, "required": ["event_type", "payload"]},
    "candidateDetectedPayload": {"type": "object", "required": ["candidate_id", "earlier_snapshot_id", "later_snapshot_id", "rule_id", "detector_version"], "properties": {"candidate_id": {"$ref": "#/$defs/uuid"}, "earlier_snapshot_id": {"$ref": "#/$defs/uuid"}, "later_snapshot_id": {"$ref": "#/$defs/uuid"}, "rule_id": {"enum": ["R1_SOURCE_CONTINUITY", "R2_REPLACE_CONTINUITY", "R3_PAPER_TITLE_TIME", "R4_NAME_TITLE_TEXT", "R5_ZERO_TEXT_LINEAGE"]}, "detector_version": {"type": "string", "minLength": 1, "maxLength": 128}}, "additionalProperties": false},
    "candidateStateEvent": {"properties": {"event_type": {"enum": ["paper_version_candidate.confirmed", "paper_version_candidate.rejected", "paper_version_candidate.reconsidered", "paper_version_candidate.superseded"]}, "payload": {"$ref": "#/$defs/candidateStatePayload"}}, "required": ["event_type", "payload"]},
    "candidateStatePayload": {"type": "object", "required": ["candidate_id", "old_status", "new_status", "row_version", "replacement_candidate_id"], "properties": {"candidate_id": {"$ref": "#/$defs/uuid"}, "old_status": {"type": "string", "minLength": 1}, "new_status": {"type": "string", "minLength": 1}, "row_version": {"type": "integer", "minimum": 1}, "replacement_candidate_id": {"$ref": "#/$defs/nullableUuid"}}, "additionalProperties": false},
    "entityMutationEvent": {"properties": {"event_type": {"enum": ["paper.created", "paper.updated", "paper.deleted", "paper.restored", "idea.created", "idea.updated", "idea.deleted", "idea.restored", "submission.created", "submission.updated", "submission.deleted", "submission.restored"]}, "payload": {"$ref": "#/$defs/entityMutationPayload"}}, "required": ["event_type", "payload"]},
    "entityMutationPayload": {"type": "object", "required": ["entity_id", "row_version", "changed_fields"], "properties": {"entity_id": {"$ref": "#/$defs/uuid"}, "row_version": {"type": "integer", "minimum": 1}, "changed_fields": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}, "additionalProperties": false},
    "submissionStatusEvent": {"properties": {"event_type": {"const": "submission.status_changed"}, "payload": {"$ref": "#/$defs/submissionStatusPayload"}}, "required": ["event_type", "payload"]},
    "submissionStatusPayload": {"type": "object", "required": ["submission_id", "old_status", "new_status", "row_version"], "properties": {"submission_id": {"$ref": "#/$defs/uuid"}, "old_status": {"type": "string", "minLength": 1}, "new_status": {"type": "string", "minLength": 1}, "row_version": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "paperVersionEvent": {"properties": {"event_type": {"enum": ["paper_version.confirmed", "paper_version.retracted", "paper_version.context_parse_changed"]}, "payload": {"$ref": "#/$defs/paperVersionPayload"}}, "required": ["event_type", "payload"]},
    "paperVersionPayload": {"type": "object", "required": ["paper_version_id", "paper_id", "source_snapshot_id", "row_version", "old_context_parse_artifact_id", "new_context_parse_artifact_id"], "properties": {"paper_version_id": {"$ref": "#/$defs/uuid"}, "paper_id": {"$ref": "#/$defs/uuid"}, "source_snapshot_id": {"$ref": "#/$defs/uuid"}, "row_version": {"type": "integer", "minimum": 1}, "old_context_parse_artifact_id": {"$ref": "#/$defs/nullableUuid"}, "new_context_parse_artifact_id": {"$ref": "#/$defs/nullableUuid"}}, "additionalProperties": false},
    "currentVersionEvent": {"properties": {"event_type": {"const": "paper.current_version_changed"}, "payload": {"$ref": "#/$defs/currentVersionPayload"}}, "required": ["event_type", "payload"]},
    "currentVersionPayload": {"type": "object", "required": ["paper_id", "old_paper_version_id", "new_paper_version_id", "row_version"], "properties": {"paper_id": {"$ref": "#/$defs/uuid"}, "old_paper_version_id": {"$ref": "#/$defs/nullableUuid"}, "new_paper_version_id": {"$ref": "#/$defs/nullableUuid"}, "row_version": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "versionRelationEvent": {"properties": {"event_type": {"enum": ["paper_version_relation.created", "paper_version_relation.retracted"]}, "payload": {"$ref": "#/$defs/versionRelationPayload"}}, "required": ["event_type", "payload"]},
    "versionRelationPayload": {"type": "object", "required": ["relation_id", "later_paper_version_id", "earlier_paper_version_id", "row_version"], "properties": {"relation_id": {"$ref": "#/$defs/uuid"}, "later_paper_version_id": {"$ref": "#/$defs/uuid"}, "earlier_paper_version_id": {"$ref": "#/$defs/uuid"}, "row_version": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "relationStateEvent": {"properties": {"event_type": {"enum": ["relation.confirmed", "relation.rejected", "relation.reconsidered", "relation.retracted", "relation.superseded"]}, "payload": {"$ref": "#/$defs/relationStatePayload"}}, "required": ["event_type", "payload"]},
    "relationStatePayload": {"type": "object", "required": ["relation_id", "relation_type", "old_state", "new_state", "row_version"], "properties": {"relation_id": {"$ref": "#/$defs/uuid"}, "relation_type": {"type": "string", "minLength": 1}, "old_state": {"type": ["string", "null"]}, "new_state": {"type": ["string", "null"]}, "row_version": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "undoEvent": {"properties": {"event_type": {"const": "command.undo_applied"}, "payload": {"$ref": "#/$defs/undoPayload"}}, "required": ["event_type", "payload"]},
    "undoPayload": {"type": "object", "required": ["undo_command_id", "original_command_id", "affected_entity_ids"], "properties": {"undo_command_id": {"$ref": "#/$defs/uuid"}, "original_command_id": {"$ref": "#/$defs/uuid"}, "affected_entity_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/uuid"}}}, "additionalProperties": false},
    "backupEvent": {"properties": {"event_type": {"const": "backup.completed"}, "payload": {"$ref": "#/$defs/backupPayload"}}, "required": ["event_type", "payload"]},
    "backupPayload": {"type": "object", "required": ["backup_id", "manifest_sha256", "file_count", "total_bytes"], "properties": {"backup_id": {"$ref": "#/$defs/uuid"}, "manifest_sha256": {"$ref": "#/$defs/sha256"}, "file_count": {"type": "integer", "minimum": 0}, "total_bytes": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "exportEvent": {"properties": {"event_type": {"const": "export.completed"}, "payload": {"$ref": "#/$defs/exportPayload"}}, "required": ["event_type", "payload"]},
    "exportPayload": {"type": "object", "required": ["export_id", "manifest_sha256", "dataset_counts", "total_bytes"], "properties": {"export_id": {"$ref": "#/$defs/uuid"}, "manifest_sha256": {"$ref": "#/$defs/sha256"}, "dataset_counts": {"type": "object", "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"}, "additionalProperties": {"type": "integer", "minimum": 0}}, "total_bytes": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "restorePreparedEvent": {"properties": {"event_type": {"const": "restore.prepared"}, "payload": {"$ref": "#/$defs/restorePreparedPayload"}}, "required": ["event_type", "payload"]},
    "restorePreparedPayload": {"type": "object", "required": ["backup_id", "maintenance_operation_id", "target_path_hash"], "properties": {"backup_id": {"$ref": "#/$defs/uuid"}, "maintenance_operation_id": {"$ref": "#/$defs/uuid"}, "target_path_hash": {"$ref": "#/$defs/sha256"}}, "additionalProperties": false},
    "restoreActivatedEvent": {"properties": {"event_type": {"const": "workspace.restore_activated"}, "payload": {"$ref": "#/$defs/restoreActivatedPayload"}}, "required": ["event_type", "payload"]},
    "restoreActivatedPayload": {"type": "object", "required": ["backup_id", "maintenance_operation_id", "workspace_id"], "properties": {"backup_id": {"$ref": "#/$defs/uuid"}, "maintenance_operation_id": {"$ref": "#/$defs/uuid"}, "workspace_id": {"$ref": "#/$defs/uuid"}}, "additionalProperties": false},
    "migrationEvent": {"properties": {"event_type": {"const": "maintenance.migration_completed"}, "payload": {"$ref": "#/$defs/migrationPayload"}}, "required": ["event_type", "payload"]},
    "migrationPayload": {"type": "object", "required": ["migration_batch_id", "source_revision", "target_revision", "counts_digest"], "properties": {"migration_batch_id": {"$ref": "#/$defs/uuid"}, "source_revision": {"type": "string", "minLength": 1}, "target_revision": {"type": "string", "minLength": 1}, "counts_digest": {"$ref": "#/$defs/sha256"}}, "additionalProperties": false}
  }
}
