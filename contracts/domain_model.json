      "supports": {"source": ["EvidenceRef"], "target": ["Paper", "PaperVersion", "Idea"], "symmetric": false},
      "contradicts": {"source": ["EvidenceRef"], "target": ["Paper", "PaperVersion", "Idea"], "symmetric": false},
      "extends": {"source": ["Paper", "Idea"], "target": ["same_entity_type"], "symmetric": false},
      "related_to": {"source": ["Paper", "Idea"], "target": ["same_entity_type"], "symmetric": true},
      "presented_at": {"source": ["Paper"], "target": ["Conference"], "symmetric": false, "read_only": true},
      "submitted_as": {"source": ["PaperVersion"], "target": ["Submission"], "symmetric": false},
      "split_from": {"source": ["Paper"], "target": ["Paper"], "symmetric": false},
      "merged_from": {"source": ["Paper"], "target": ["Paper"], "symmetric": false}
