 <widget class="QWidget" name="overviewPage">
  <property name="styleSheet"><string notr="true">
QFrame[card="true"] { background: #FFFFFF; border: 1px solid #E4E7EC; border-radius: 14px; }
QLabel#pageTitleLabel { color: #172033; font-size: 18pt; font-weight: 600; }
QLabel#pageSubtitleLabel, QLabel#revisionHelpLabel, QLabel#readyHelpLabel,
QLabel#conferenceHelpLabel, QLabel#grantHelpLabel, QLabel#suggestionsEmptyBodyLabel {
  color: #667085;
  font-size: 9pt;
}
QLabel[sectionTitle="true"] { color: #172033; font-size: 12pt; font-weight: 600; }
QLabel[kpi="true"] { color: #172033; font-size: 21pt; font-weight: 600; }
QLabel[icon="true"] { color: #4F7DFF; font-size: 13pt; font-weight: 600; }
QPushButton {
  min-height: 36px;
  border: 1px solid #E4E7EC;
  border-radius: 8px;
  padding: 0 14px;
  background: #FFFFFF;
  color: #172033;
}
QPushButton:hover { background: #F5F7FB; }
QPushButton#saveIdeaButton, QPushButton#organizeNowButton {
  background: #4F7DFF;
  border-color: #4F7DFF;
  color: #FFFFFF;
}
QPushButton#saveIdeaButton:hover, QPushButton#organizeNowButton:hover {
  background: #356AE6;
  border-color: #356AE6;
}
QLineEdit {
  min-height: 36px;
  border: 1px solid #E4E7EC;
  border-radius: 8px;
  padding: 0 12px;
  background: #FFFFFF;
}
QListWidget, QTableWidget {
  border: 1px solid #E4E7EC;
  border-radius: 8px;
  background: #FFFFFF;
  alternate-background-color: #F9FAFB;
}
QHeaderView::section {
  background: #F6F8FC;
  color: #667085;
  border: 0;
  border-bottom: 1px solid #E4E7EC;
  padding: 8px;
}
QTableWidget::item { border-bottom: 1px solid #F2F4F7; padding: 8px; }
QTableWidget::item:hover { background: #F5F7FB; }
